# ---------------------------------------------
# Shared (required in all environments)
# ---------------------------------------------
# Neon PostgreSQL pooled connection string from https://neon.tech
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# Better Auth secret (generate a long random string in production)
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# ---------------------------------------------
# Local Docker Compose defaults
# ---------------------------------------------
PORT=3001
WEB_ORIGIN=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
INTERNAL_API_URL=http://server:3001

# ---------------------------------------------
# Vercel (apps/web)
# ---------------------------------------------
# NEXT_PUBLIC_APP_URL=https://your-web-domain.vercel.app
# INTERNAL_API_URL=https://your-render-api.onrender.com

# ---------------------------------------------
# Render (apps/server)
# ---------------------------------------------
# PORT is auto-provided by Render.
# WEB_ORIGIN=https://your-web-domain.vercel.app
# BETTER_AUTH_URL=https://your-web-domain.vercel.app
